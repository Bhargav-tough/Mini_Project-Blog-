<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Profile</title>

    <script src="https://cdn.tailwindcss.com"></script>

</head>



<body class="bg-zinc-900 text-white min-h-screen p-10">



    <!-- Header -->

    <div class="flex justify-between items-center">


    <div class="flex items-center gap-4">


      <% if(user.profilepic === "default.jpg"){ %>

<img 
src="/images/default.jpg"
class="w-16 h-16 rounded-full object-cover border"
>

<% } else { %>

<img 
src="/images/uploads/<%= user.profilepic %>"
class="w-16 h-16 rounded-full object-cover border"
>

<% } %>

        <h1 class="text-3xl font-light">

            Hello,
            <span class="font-bold">
                <%= user.name %>
            </span>
            👋

        </h1>


    </div>




    <a href="/logout"
    class="bg-red-500 px-5 py-2 rounded-md hover:bg-red-600">

        Logout

    </a>


</div>







    <!-- Create Post -->


    <div class="mt-10">


        <h2 class="text-xl mb-5">

            Create a new post

        </h2>



        <form action="/post" method="post">


            <textarea
                name="content"
                placeholder="What's on your mind?"
                class="w-1/3 h-32 bg-transparent border-2 border-zinc-700 rounded-md p-3 outline-none resize-none"></textarea>



            <br>



            <button
                type="submit"
                class="mt-3 px-5 py-2 bg-blue-500 rounded-md hover:bg-blue-600">

                Create Post

            </button>



        </form>



    </div>









    <!-- Posts Section -->


    <div class="mt-20">


        <h2 class="text-2xl text-zinc-400 mb-5">

            Your Posts

        </h2>




        <div class="flex flex-col gap-5">





            <% if(posts && posts.length > 0) { %>




                <% posts.forEach(post => { %>





                    <div class="bg-zinc-800 border border-zinc-700 rounded-md p-5 w-1/3">





                        <h3 class="text-blue-400 text-lg">

                            @<%= user.username %>

                        </h3>





                        <p class="mt-3 text-zinc-200">

                            <%= post.content %>

                        </p>







                        <div class="flex gap-5 mt-5">





                            <!-- Like / Unlike -->

                            <a href="/like/<%= post._id %>"
                                class="text-blue-500">


                                <% if(post.likes && post.likes.length > 0) { %>

                                    Unlike ❤️

                                <% } else { %>

                                    Like 🤍

                                <% } %>


                            </a>






                            <!-- Edit -->

                            <a href="/edit/<%= post._id %>"
                                class="text-zinc-400">

                                Edit

                            </a>






                            <!-- Delete -->

                            <a href="/delete/<%= post._id %>"
                                class="text-red-500">

                                Delete

                            </a>





                        </div>







                        <!-- Like Count -->


                        <p class="text-zinc-500 mt-3">

                            Likes:
                            <%= post.likes ? post.likes.length : 0 %>

                        </p>





                    </div>






                <% }) %>






            <% } else { %>





                <p class="text-zinc-500">

                    No posts yet.

                </p>





            <% } %>






        </div>





    </div>







</body>

</html>