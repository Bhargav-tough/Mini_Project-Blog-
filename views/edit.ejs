<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Post</title>

    <script src="https://cdn.tailwindcss.com"></script>

</head>



<body class="bg-zinc-900 text-white min-h-screen p-10">



    <!-- Header -->

    <div class="flex justify-between items-center">


        <h1 class="text-3xl font-light">

            Edit Your Post ✏️

        </h1>



        <a href="/logout"
            class="bg-red-500 px-5 py-2 rounded-md hover:bg-red-600">

            Logout

        </a>


    </div>





    <!-- Edit Post Form -->


    <div class="mt-10">


        <h2 class="text-xl mb-5">

            Update your post

        </h2>




        <form action="/update/<%= post._id %>" method="post">



            <textarea
                name="content"
                placeholder="Write your post..."
                class="w-1/3 h-32 bg-transparent border-2 border-zinc-700 rounded-md p-3 outline-none resize-none"><%= post.content %></textarea>




            <br>




            <button
                type="submit"
                class="mt-3 px-5 py-2 bg-yellow-500 rounded-md hover:bg-yellow-600">

                Update Post

            </button>



        </form>



    </div>





    <!-- Back Button -->


    <div class="mt-5">


        <a href="/profile"
            class="text-blue-400">

            ← Back to Profile

        </a>


    </div>





</body>

</html>